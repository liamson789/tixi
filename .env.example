GOOGLE_CLIENT_ID=tu-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-google-client-secret
SECRET_KEY=tu-django-secret-key
DEBUG=False
ALLOWED_HOSTS=tixxi.io,www.tixxi.io
CSRF_TRUSTED_ORIGINS=https://tixxi.io,https://www.tixxi.io
ACCOUNT_DEFAULT_HTTP_PROTOCOL=https
APP_BASE_URL=https://tixxi.io
NGROK_URL=
WOMPI_API_SECRET=tu-wompi-api-secret
WOMPI_INTEGRITY_KEY=tu-wompi-integrity-key
WOMPI_PUBLIC_KEY=tu-wompi-public-key
WOMPI_PRIVATE_KEY=tu-wompi-private-key

# DigitalOcean Spaces (media)
USE_DO_SPACES=False
DO_SPACES_KEY=tu-spaces-key
DO_SPACES_SECRET=tu-spaces-secret
DO_SPACES_BUCKET=tu-bucket
DO_SPACES_REGION=nyc3
DO_SPACES_ENDPOINT_URL=https://nyc3.digitaloceanspaces.com
DO_SPACES_CDN_DOMAIN=tu-bucket.nyc3.digitaloceanspaces.com
DO_SPACES_LOCATION=media
DO_SPACES_DEFAULT_ACL=
SERVE_MEDIA=True

# Seguridad recomendada en producción
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
